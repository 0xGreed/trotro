# Sui gRPC endpoint (Chainstack, QuickNode, etc.). JSON-RPC is deprecated.
GRPC_URL=https://sui-mainnet.example.com
GRPC_X_TOKEN=replace-me

# Bech32-encoded (suiprivkey1...) or hex secret key for the executing wallet.
PRIVATE_KEY=suiprivkey1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Scallop address object ID (mainnet); see @scallop-io/sui-scallop-sdk docs.
SCALLOP_ADDRESS_ID=67c44a103e30bcb76d3cbb6d3a81b5b6

# Safety switches.
DRY_RUN=true
PROFIT_BPS_MIN=50      # 0.5% — execute only if final profit ≥ this
MIN_PROFIT_USD=0.3     # $ — execute only if estimated USD profit ≥ this
PREFILTER_BPS=10       # 0.1% — cheap-scan threshold to escalate to full sweep
SLIPPAGE_BPS=30        # 0.3%

# Notional sweep in USD equivalent (comma-separated).
USD_NOTIONALS=100,1000,10000

# Cap pair universe to top-N Scallop pools ranked by USD TVL. 0 = no cap.
TOP_LOANABLE=15

# Runner cadence (ms) and log level.
POLL_INTERVAL_MS=5000
LOG_LEVEL=info
