# Sui gRPC endpoint (Chainstack, QuickNode, etc.). JSON-RPC is deprecated.
GRPC_URL=https://sui-mainnet.example.com
GRPC_X_TOKEN=replace-me

# Bech32-encoded (suiprivkey1...) or hex secret key for the executing wallet.
PRIVATE_KEY=suiprivkey1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Scallop address object ID (mainnet); see @scallop-io/sui-scallop-sdk docs.
SCALLOP_ADDRESS_ID=67c44a103e30bcb76d3cbb6d3a81b5b6

# Safety switches.
DRY_RUN=true
PROFIT_BPS_MIN=50 # 0.5%
SLIPPAGE_BPS=30   # 0.3%

# Runner cadence (ms) and log level.
POLL_INTERVAL_MS=2000
LOG_LEVEL=info
